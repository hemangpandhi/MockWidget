<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/glass_panel"
        android:padding="24dp"
        android:gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            
            <!-- Album Art -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/glass_card_inner"
                android:layout_marginRight="16dp">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_media_play"
                    android:tint="#00E5FF"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/media_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOW PLAYING"
                    android:textColor="#00E5FF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/track_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Starlight Symphony"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/artist_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nebula Waves"
                    android:textColor="#B3FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Progress Bar -->
        <SeekBar
            android:id="@+id/playback_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="42"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:progressTint="#00E5FF"
            android:thumbTint="#00E5FF"/>

        <!-- Media Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_prev"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/glass_button_bg"
                android:src="@android:drawable/ic_media_previous"
                android:tint="#FFFFFF"
                android:elevation="4dp"/>

            <ImageButton
                android:id="@+id/btn_play"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/glass_button_active_bg"
                android:src="@android:drawable/ic_media_pause"
                android:tint="#00E5FF"
                android:layout_marginLeft="24dp"
                android:layout_marginRight="24dp"
                android:elevation="8dp"/>

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/glass_button_bg"
                android:src="@android:drawable/ic_media_next"
                android:tint="#FFFFFF"
                android:elevation="4dp"/>
                
            <Button
                android:id="@+id/btn_focus"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Focus"
                android:layout_marginLeft="24dp"
                android:background="@drawable/glass_button_bg"
                android:textColor="#B3FFFFFF"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
